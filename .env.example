# Azure AD App Registration (required)
# Register at: https://portal.azure.com → App registrations → New registration
# Platform: Mobile and desktop applications (for device code flow)
O365_TENANT_ID=your-tenant-id
O365_CLIENT_ID=your-client-id

# Client secret (optional — required for client_credentials flow, not needed for device code)
O365_CLIENT_SECRET=

# Auth mode: "device_code" (interactive) or "client_credentials" (headless/CI)
O365_AUTH_MODE=device_code

# Write protection (default: false)
# Set to "true" to enable send, reply, forward, create, update, delete operations
O365_WRITE_ENABLED=false

# Token cache directory (default: ~/.office365-blade-mcp/)
O365_TOKEN_CACHE_DIR=

# Transport (default: stdio)
O365_MCP_TRANSPORT=stdio
O365_MCP_HOST=127.0.0.1
O365_MCP_PORT=8770

# Bearer token for HTTP transport auth (disabled if empty)
O365_MCP_API_TOKEN=
